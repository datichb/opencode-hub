{
  "name": "@opencode-hub/context-mode-plugin",
  "version": "1.0.0",
  "description": "Context-Mode plugin for OpenCode — reduces token usage on read/webfetch/MCP outputs via sandboxing, session continuity after compaction, and Think in Code patterns. Complementary to RTK (which covers bash outputs).",
  "type": "module",
  "main": "context-mode.ts",
  "exports": {
    ".": "./context-mode.ts"
  },
  "engines": {
    "node": ">=22.5.0",
    "bun": ">=1.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "context-mode": "^1.0.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.15.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "keywords": [
    "opencode",
    "context-mode",
    "token-optimization",
    "plugin",
    "sandbox",
    "session-continuity"
  ],
  "author": "opencode-hub contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/datichb/opencode-hub.git",
    "directory": "plugins/context-mode"
  }
}
