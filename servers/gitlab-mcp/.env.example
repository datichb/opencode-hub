# GitLab MCP Server — Variables d'environnement

# Token d'accès personnel GitLab (obligatoire)
# Scopes requis : api, read_user
# Format : glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_PERSONAL_ACCESS_TOKEN=

# URL de base de votre instance GitLab (optionnel)
# Par défaut : https://gitlab.com
# Pour une instance self-hosted : https://gitlab.monentreprise.com
GITLAB_BASE_URL=https://gitlab.com

# Timeout des requêtes en millisecondes (optionnel, défaut : 30000)
GITLAB_TIMEOUT=30000

# Nombre maximum de tentatives en cas d'erreur (optionnel, défaut : 2)
GITLAB_MAX_RETRIES=2
